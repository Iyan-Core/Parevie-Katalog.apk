# ─────────────────────────────────────────────────────────
# KatalogPro — Environment Variables
# Salin file ini menjadi .env dan isi dengan nilai Firebase Anda
# JANGAN commit file .env ke repository!
# ─────────────────────────────────────────────────────────

# Firebase Configuration
# Dapatkan dari: Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Admin Panel Password (untuk login di APK)
VITE_ADMIN_PASSWORD=admin123

# Admin Token (harus sama dengan string di firestore.rules → isAdmin() function)
# Ganti dengan string acak yang panjang — ini kunci keamanan database kamu!
VITE_ADMIN_TOKEN=RAHASIA_ADMIN_KAMU_2025_XyZ9
